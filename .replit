run = "npm run install:all && npm run build && npm start"
entrypoint = "server/src/index.ts"
modules = ["nodejs-20:v8-20230920-bd784b9"]

[nix]
channel = "stable-24_05"

[env]
PORT = "3000"

[[ports]]
localPort = 3000
externalPort = 80

[agent]
expertMode = true

[deployment]
run = ["sh", "-c", "npm run install:all && npm run build && npm start"]
build = ["sh", "-c", "echo done"]
